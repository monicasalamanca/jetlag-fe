# Strapi CMS
NEXT_PUBLIC_STRAPI_URL=
NEXT_PUBLIC_STRAPI_API_TOKEN=
STRAPI_URL=
STRAPI_READ_API_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=https://thejetlagchronicles.com
NEXT_PUBLIC_SITE_NAME=The Jet Lag Chronicles
NEXT_PUBLIC_SITE_DESCRIPTION=
NEXT_PUBLIC_CONTACT_EMAIL=

# Google Analytics
NEXT_PUBLIC_GA_ID=

# Google AdSense
# (configure via next.config.ts or layout.tsx)

# Kit (ConvertKit) email platform
KIT_API_KEY=
KIT_SUBSCRIBE_FORM_ID=
KIT_THAILAND_GUIDE_FORM_ID=

# Social links
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_INSTAGRAM_URL=

# Logo
NEXT_PUBLIC_LOGO_URL=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_URL=https://res.cloudinary.com/jetlagchronicles/image/upload

# Google reCAPTCHA v3
# Create keys at https://www.google.com/recaptcha/admin — choose "reCAPTCHA v3"
# Add thejetlagchronicles.com (and localhost for dev) as allowed domains
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=   # public key — safe to expose in client bundle
RECAPTCHA_SECRET_KEY=             # private key — server-side only, never expose
